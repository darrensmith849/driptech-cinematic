---
// Shared "services" section → cinematic APPROACH (hairline rows).
import Lines from "../Lines.astro";
const { eyebrow, title = "", items = [] } = Astro.props;
---
<section class="pad wrap">
  <div class="approach-head">
    {eyebrow && <span class="label" data-reveal>{eyebrow}</span>}
    <h2 class="d-lg reveal-lines" data-reveal style="margin-top:1.1rem"><Lines html={title} /></h2>
  </div>
  <div class="approach">
    {items.map((it: any, i: number) => (
      <div class="appr" data-reveal>
        <span class="an">{String(i + 1).padStart(2, "0")}</span>
        <span class="at">{it.title}</span>
        <span class="ad">{it.blurb}</span>
      </div>
    ))}
  </div>
</section>
