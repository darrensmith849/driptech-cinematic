---
import Lines from "../Lines.astro";
import { business } from "../../lib/content";
const { eyebrow, title, intro } = Astro.props;
const b = business;
---
<section class="pad wrap">
  <div class="clients-head">
    {eyebrow && <span class="label" data-reveal>{eyebrow}</span>}
    {title && <h2 class="d-lg reveal-lines" data-reveal style="margin-top:1.1rem"><Lines html={title} /></h2>}
    {intro && <p class="lead" data-reveal style="margin-top:1.2rem">{intro}</p>}
  </div>
  <div class="contact-grid" style="margin-top:clamp(2rem,4vw,3rem)">
    <div data-reveal>
      {b.email && <a class="email-lg" href={`mailto:${b.email}`} data-cursor>{b.email}</a>}
    </div>
    <div class="contact-detail" data-reveal>
      {b.address && <span>{b.address}</span>}
      {b.phoneDisplay && <a href={`tel:${b.phoneE164 ?? b.phoneDisplay}`}>{b.phoneDisplay}</a>}
      {b.social.instagram && <a href={b.social.instagram}>Instagram</a>}
    </div>
  </div>
</section>
