---
import { business, anchorNav, headerCta } from "../lib/content";
const b = business;
const links = anchorNav();
const cta = headerCta();
---
<header class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="wordmark" aria-label={b.name}><span class="dot"></span>{b.name}</a>
    <nav class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav-right">
      <a href={cta.href} class="link">{cta.label}</a>
      <div class="burger" id="burger" role="button" aria-label="Menu"><span></span><span></span></div>
    </div>
  </div>
</header>
