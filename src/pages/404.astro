---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Page not found">
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-display text-6xl font-extrabold text-primary-600">404</p>
    <h1 class="mt-4 text-2xl font-bold">Page not found</h1>
    <p class="mt-2 text-slate-600">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-8 rounded-full bg-primary-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-primary-700">Back home</a>
  </section>
</Layout>
